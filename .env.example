# ─────────────────────────────────────────────────────────────
# Database (required) — Turso (libSQL) in production, or a local
# SQLite file for development. Read by lib/db.ts and prisma/seed.ts.
# ─────────────────────────────────────────────────────────────

# Production / shared dev — Turso:
#   turso db create <name>
#   turso db show <name>            -> copy the libsql:// URL here
#   turso db tokens create <name>   -> copy the token into DATABASE_AUTH_TOKEN
DATABASE_URL="libsql://<your-db>-<org>.aws-us-east-1.turso.io"
DATABASE_AUTH_TOKEN="<turso-db-token>"

# Local-only alternative (no token needed). Comment the two lines above
# and uncomment this to run against a throwaway file:
# DATABASE_URL="file:./dev.db"

# ─────────────────────────────────────────────────────────────
# Tracking (optional) — leave blank for "demo mode":
#   - GTM script is simply not injected when NEXT_PUBLIC_GTM_ID is unset.
#   - Server-side GA4 events log to the console instead of being sent.
# See DECISIONS.md D-006.
# ─────────────────────────────────────────────────────────────
# NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"
# GA4_MEASUREMENT_ID="G-XXXXXXXXXX"          # Admin > Data Streams > your web stream
# GA4_API_SECRET="xxxxxxxxxxxxxxxxxxxxxx"    # …same stream > Measurement Protocol API secrets > Create
# GA4_DEBUG_MODE="true"                      # optional: surfaces events in GA4 DebugView for live demos
